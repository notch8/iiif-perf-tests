# Copy to .env (gitignored) and run tests via:
#   op run --env-file=.env -- npx playwright test
#
# Required for every run:
IIIF_TEST_HOST=demo.hykuup.com
IIIF_TEST_WORKS=/concern/images/3812ff57-82e2-4d73-8cd8-9617fdfb3c44

# Optional: only needed for deployments with an existing monitoring
# User-Agent allowance. Never put the literal value here or in any
# committed file — reference it from 1Password instead:
IIIF_TEST_UA=op://DevOps/iiif-perf-tests monitoring UA/credential
